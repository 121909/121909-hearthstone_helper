{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.discard-advisor.local/v1/common.schema.json",
  "title": "Discard Advisor common protocol types",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "semanticVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "entityId": {
      "type": "integer",
      "minimum": 1
    },
    "cardId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_]+$"
    },
    "deckEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cardId",
        "count"
      ],
      "properties": {
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        }
      }
    },
    "entityReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        }
      }
    },
    "hero": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "cardId",
        "health",
        "maxHealth",
        "armor",
        "attack",
        "frozen",
        "immune",
        "attacksThisTurn",
        "maxAttacksThisTurn"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "health": {
          "type": "integer",
          "minimum": 0
        },
        "maxHealth": {
          "type": "integer",
          "minimum": 1
        },
        "armor": {
          "type": "integer",
          "minimum": 0
        },
        "attack": {
          "type": "integer",
          "minimum": 0
        },
        "frozen": {
          "type": "boolean"
        },
        "immune": {
          "type": "boolean"
        },
        "attacksThisTurn": {
          "type": "integer",
          "minimum": 0
        },
        "maxAttacksThisTurn": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "weapon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "cardId",
        "attack",
        "durability"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "attack": {
          "type": "integer",
          "minimum": 0
        },
        "durability": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "heroPower": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "cardId",
        "cost",
        "available",
        "usesThisTurn",
        "maxUsesThisTurn"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "cost": {
          "type": "integer",
          "minimum": 0
        },
        "available": {
          "type": "boolean"
        },
        "usesThisTurn": {
          "type": "integer",
          "minimum": 0
        },
        "maxUsesThisTurn": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "mana": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "temporary",
        "spent",
        "maximum",
        "locked",
        "overloadedNextTurn"
      ],
      "properties": {
        "available": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "temporary": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "spent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "maximum": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "locked": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "overloadedNextTurn": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        }
      }
    },
    "handCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "cardId",
        "zonePosition",
        "dynamicCost",
        "temporary"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "zonePosition": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "dynamicCost": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99
        },
        "createdByEntityId": {
          "$ref": "#/$defs/entityId"
        },
        "temporary": {
          "type": "boolean"
        },
        "temporaryUntilTurn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "minion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "cardId",
        "boardPosition",
        "attack",
        "health",
        "maxHealth",
        "attacksThisTurn",
        "maxAttacksThisTurn",
        "frozen",
        "dormant",
        "taunt",
        "rush",
        "charge",
        "stealth",
        "divineShield",
        "poisonous",
        "lifesteal",
        "reborn",
        "immune",
        "silenced",
        "summonedThisTurn",
        "canAttack"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "boardPosition": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "attack": {
          "type": "integer",
          "minimum": 0
        },
        "health": {
          "type": "integer",
          "minimum": 0
        },
        "maxHealth": {
          "type": "integer",
          "minimum": 1
        },
        "attacksThisTurn": {
          "type": "integer",
          "minimum": 0
        },
        "maxAttacksThisTurn": {
          "type": "integer",
          "minimum": 0
        },
        "frozen": {
          "type": "boolean"
        },
        "dormant": {
          "type": "boolean"
        },
        "taunt": {
          "type": "boolean"
        },
        "rush": {
          "type": "boolean"
        },
        "charge": {
          "type": "boolean"
        },
        "stealth": {
          "type": "boolean"
        },
        "divineShield": {
          "type": "boolean"
        },
        "poisonous": {
          "type": "boolean"
        },
        "lifesteal": {
          "type": "boolean"
        },
        "reborn": {
          "type": "boolean"
        },
        "immune": {
          "type": "boolean"
        },
        "silenced": {
          "type": "boolean"
        },
        "summonedThisTurn": {
          "type": "boolean"
        },
        "canAttack": {
          "type": "boolean"
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "cardId",
        "boardPosition",
        "durability",
        "cooldown",
        "available"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "boardPosition": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "durability": {
          "type": "integer",
          "minimum": 0
        },
        "cooldown": {
          "type": "integer",
          "minimum": 0
        },
        "available": {
          "type": "boolean"
        }
      }
    },
    "zoneCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "cardId"
      ],
      "properties": {
        "entityId": {
          "$ref": "#/$defs/entityId"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "createdByEntityId": {
          "$ref": "#/$defs/entityId"
        }
      }
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "choiceId",
        "choiceType",
        "candidates"
      ],
      "properties": {
        "choiceId": {
          "type": "integer",
          "minimum": 1
        },
        "choiceType": {
          "type": "string",
          "enum": [
            "DISCOVER",
            "MULLIGAN",
            "TARGET",
            "HAND_DISCARD",
            "OTHER"
          ]
        },
        "sourceEntityId": {
          "$ref": "#/$defs/entityId"
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/entityReference"
          }
        }
      }
    },
    "scoreDimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lethal",
        "survival",
        "board",
        "discardValue",
        "resources",
        "temporaryValue",
        "boardSpace",
        "directDamage",
        "selfDamage",
        "dukeGrowth",
        "opponentPressure"
      ],
      "properties": {
        "lethal": {
          "type": "number"
        },
        "survival": {
          "type": "number"
        },
        "board": {
          "type": "number"
        },
        "discardValue": {
          "type": "number"
        },
        "resources": {
          "type": "number"
        },
        "temporaryValue": {
          "type": "number"
        },
        "boardSpace": {
          "type": "number"
        },
        "directDamage": {
          "type": "number"
        },
        "selfDamage": {
          "type": "number"
        },
        "dukeGrowth": {
          "type": "number"
        },
        "opponentPressure": {
          "type": "number"
        }
      }
    }
  }
}
